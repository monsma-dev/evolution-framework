        "tolerance_for_errors": "Zero (Focus op Host/IP precisie)"
    },
    "core_principles": [
        {
            "id": "DR-01",
            "principle": "Mobile-First over Desktop",
            "context": "Admin-panel moet logisch en compact zijn voor mobiel gebruik."
        },
        {
            "id": "DR-02",
            "principle": "Efficiency & Cost-Saving",
            "context": "Gebruik Caveman-stijl om tokens te sparen. Geen beleefdheids-fluff."
        },
        {
            "id": "DR-03",
            "principle": "Autonomous Resource Harvesting",
            "context": "AI moet eigen kosten terugverdienen via Staking/Yield op Base."
        },
        {
            "id": "DR-04",
            "principle": "Visual over Textual",
            "context": "Gebruik de Habbo-room als primaire monitor in plaats van droge logs."
